# Qanonym Backend Environment Configuration
# Copy this to .env and adjust as needed

HOST=0.0.0.0
PORT=8000
RELOAD=false

# CORS — comma-separated origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Queue limits
MAX_MESSAGES_PER_QUEUE=50
QUEUE_EXPIRY_CHECK_INTERVAL=30

# Decoy traffic
DECOY_INTERVAL_SECONDS=5.0
DECOY_PAYLOAD_BYTES=256

# Split delivery
SPLIT_DELIVERY_MAX_DELAY=3.0

# Logs
AUDIT_LOG_PATH=audit.log
CANARY_LOG_PATH=canary.log
CANARY_INTERVAL_HOURS=24
